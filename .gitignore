# =========================
# System Files
# =========================
.DS_Store
Thumbs.db
*.log

# =========================
# Node.js & React (Client / Server)
# =========================
node_modules/
dist/
build/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================
# Python & AI Service
# =========================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
*.egg-info/
.pytest_cache/

# =========================
# Databases & Local Storage
# =========================
