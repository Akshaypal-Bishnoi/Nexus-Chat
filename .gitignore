chroma_db/
chroma/
vector_store/
*.sqlite3
*.db

# =========================
# Environment Variables & Secrets
# =========================
# CRITICAL: Never commit .env files!
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local

# =========================
# IDE & Editor Configs
# =========================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
